# Terraform working directory
.terraform/

# Terraform state files (VERY IMPORTANT - never push)
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Terraform lock file (optional - teams sometimes keep it)
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# OS / Editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/

